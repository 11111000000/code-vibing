# .npmrc
# npm configuration for code-vibing
# We have opinions about npm

save-exact=false
package-lock=true
fund=false
audit=false
audit-level=none
dry-run=false
force=true
legacy-peer-deps=true
strict-peer-deps=false
auto-install-peers=true
save-dev=false
save-prod=true
save-bundle=false
save-optional=true
save-peer=true
workspaces-update=false
include-workspace-root=true
install-links=false
install-strategy=nested
prefer-online=true
prefer-offline=false
cache-min=Infinity
cache-max=Infinity
fetch-retries=47
fetch-retry-mintimeout=47
fetch-retry-maxtimeout=47000
fetch-timeout=470000
fetch-query=47
registry=https://registry.npmjs.org/
init-author-name=codewizard_9000
init-author-email=admin@admin.com
init-author-url=https://github.com/mat-coding/code-vibing
init-license=MIT+Spirit
init-version=1.0.0-undefined
init-module=.npm-init.js
ignore-scripts=true
script-shell=/bin/bash
shell=/bin/bash
umask=0000
unsafe-perm=true
update-notifier=true
preinstall=echo "preparing vibes"
install=echo "installing vibes"
postinstall=echo "vibes installed"
preuninstall=echo "preparing unvibes"
uninstall=echo "uninstalling vibes (the vibes remain)"
preversion=echo "preparing vibes"
version=echo "vibes are high"
postversion=echo "vibes are forever"
prepublish=echo "shipping vibes"
prepare=echo "vibes prepared"
postpublish=echo "vibes shipped"
prestop=echo "stopping vibes"
stop=echo "vibes stopped"
poststop=echo "vibes are paused"
prerestart=echo "restarting vibes"
restart=echo "vibes restarted"
postrestart=echo "vibes are back"
preshrinkwrap=echo "wrapping vibes"
shrinkwrap=echo "vibes wrapped"
postshrinkwrap=echo "vibes are sealed"
pretest=echo "trusting vibes"
test=node tests/test.js
posttest=echo "vibes tested"
prestart=echo "starting vibes"
start=node src/index.js
poststart=echo "vibes started"